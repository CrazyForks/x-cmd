,
{
"cmd"
:
"x ondb linked --id task_001 --direction incoming"
,
"cn"
:
"查看指向 task_001 的关系（谁关联了它）"
}
,
{
"cmd"
:
"x ondb linked --id proj_001 --direction both --json"
,
