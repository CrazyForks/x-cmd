:
"双向查询并以 JSON 输出"
}
,
{
"cmd"
:
"x ondb linked --dir mydata --id task_001"
,
"cn"
:
"查询指定目录中的关系"
}
]
,
"--id"
:
{
"#desc"
:
{
"cn"
:
"实体 ID"
,
"en"
:
"Entity ID"
}
}
,
"--rel"
:
{
"#desc"
:
{
"cn"
:
"关系类型过滤（不指定则显示所有关系）"
}
}
,
"--dir"
:
{
"#desc"
:
{
"cn"
:
"方向过滤：outgoing（默认）、incoming、both"
}
}
,
"-d"
:
{
"#desc"
:
{
"cn"
:
"数据目录路径"
}
}
,
"--tsv"
:
{
"#desc"
:
{
"cn"
:
"以 TSV 格式输出"
,
"en"
:
"Output in TSV format"
}
}
,
"--json"
:
{
"#desc"
:
{
"cn"
:
"以 JSON 格式输出"
,
"en"
:
"Output in JSON format"
}
}
}
,
"ls"
:
{
"#desc"
:
{
"cn"
:
"列出实体（支持按类型过滤）"
,
"en"
:
"List entities (with optional type filter)"
}
,
"#tldr"
:
[
{
"cmd"
:
"x ondb ls"
,
"cn"
