
___x_cmd_fresh___runmain(){
    ___x_cmd_fresh___runcmd "$@"
}

___x_cmd_fresh___runcmd(){
    if ___x_cmd_hascmd fresh; then
        ___x_cmd_fresh___runcmd(){  ___x_cmd_cmds fresh "$@"; }
    else
        ___x_cmd eget use fresh || return $?
        ___x_cmd_fresh___runcmd(){ "$HOME/.local/bin/fresh" "$@" ; }
    fi || return
    ___x_cmd_fresh___runcmd "$@"
}
